# Fletix — variables de entorno
# Copiar este archivo a `.env` y completar los valores. Nunca commitear `.env`.

# === Shopify OAuth (obtener desde Partner Dashboard del app) ===
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# URL pública del app desplegado (ej: https://fletix.example.com).
# En desarrollo, `shopify app dev` la sobreescribe con un tunnel temporal.
SHOPIFY_APP_URL=https://your-app.example.com

# Scopes requeridos. Debe coincidir con `access_scopes` del shopify.app.fletix.toml.
SCOPES=read_shipping,write_shipping,read_products,read_locations

# === Base de datos ===
# Producción: Postgres recomendado.
# Desarrollo local: SQLite por defecto (file:dev.sqlite) — no setear DATABASE_URL.
# DATABASE_URL=postgresql://user:pass@host:5432/fletix

# === Entorno ===
NODE_ENV=development

# === Variante de app (multi-config en mismo repo) ===
# fletix = privada/test, cityrates = pública App Store.
# Cada servicio Render setea su propio APP_VARIANT.
#
# CRITICAL: setear BOTH APP_VARIANT (server-side process.env) y VITE_APP_VARIANT
# (client-side, Vite inlines at build time) al MISMO valor. Si divergen, el
# nombre del plan que ve el server no coincide con el que compara el cliente y
# `planInfo.plan === PLAN_PRO` falla → app aparenta no tener subscripción.
APP_VARIANT=fletix
VITE_APP_VARIANT=fletix

# === Billing mode ===
# "managed"  → Shopify App Pricing (Managed Pricing). Plans configured entirely
#              in Partner Dashboard. App MUST NOT call appSubscriptionCreate;
#              it redirects the merchant to the Shopify-hosted plan selection
#              page. Required for public App Store listings that use the new
#              Shopify App Pricing model.
# "api"      → Legacy Billing API. App creates charges via appSubscriptionCreate
#              and merchant approves a confirmationUrl. Default if unset.
#
# Public deploy (cityrates) → BILLING_MODE=managed
# Legacy Fletix custom deploy → BILLING_MODE=api (or unset)
BILLING_MODE=api

# App handle for Managed Pricing plan-selection URLs. MUST match the `handle`
# field in shopify.app.<config>.toml. Required when BILLING_MODE=managed.
# Used to build:
#   admin.shopify.com/store/<store>/charges/<APP_HANDLE>/pricing_plans
# If unset, the app queries currentAppInstallation.app.handle at runtime,
# but that field is empty until the handle has been registered via
# `shopify app deploy` and the app has been installed on the shop.
APP_HANDLE=

# === Theme app extension deep link ===
# UUID de la extension de tema (obtener de Partner Dashboard / `shopify app deploy`).
# Si está vacío, el botón "Abrir editor de tema" abre el editor sin auto-activar el bloque.
# SHOPIFY_THEME_EXTENSION_UUID=
# Handle del bloque dentro de la extension (default: rate-calculator-embed).
# SHOPIFY_THEME_BLOCK_HANDLE=rate-calculator-embed

# === Opcionales ===

# Dominio custom para tiendas enterprise que no usan *.myshopify.com.
# SHOP_CUSTOM_DOMAIN=

# URL de hosting alternativa (fallback a SHOPIFY_APP_URL si no se setea).
# Usado por el carrier service callback para construir su propia URL.
# HOST=

# URL de la documentación pública del app, mostrada en el admin.
# APP_DOCS_URL=https://docs.your-app.com
#npx shopify app dev --config shopify.app.fletix.toml --theme-app-extension-port 9294