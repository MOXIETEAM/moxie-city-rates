.shopify/
.shopify.lock

# Extensiones: artefactos de build por workspace
/extensions/*/dist/
/extensions/*/node_modules/

# Cachés y herramientas
.cache/
.eslintcache
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
coverage/
.nyc_output/

# Sistema operativo
.DS_Store
Thumbs.db

