// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Una fila por tienda que instala la app. `sponsoredPro` = Pro sin suscripción Shopify (solo BD / admin).
model AppShop {
  shop           String   @id
  sponsoredPro   Boolean  @default(false)
  note           String?
  // Captured at install/re-auth from `shop { currencyCode ianaTimezone
  // billingAddress { countryCodeV2 } }`. Drives currency labels in the admin,
  // the currency code returned to Shopify at checkout, per-shop schedule
  // timezone, and the default country for new zones. Nullable so rows created
  // before this column existed (or a transient Admin API failure at install)
  // fall back to sane defaults (COP / America/Bogota / CO) at the call site.
  currency       String?
  ianaTimezone   String?
  country        String?
  // City fuzzy-match threshold as a percentage (0-100). At checkout a customer
  // city is homologated to a configured city/alias when their similarity ratio
  // (1 - levenshtein/maxLen) is >= this / 100. Default 85.
  cityMatchThreshold Int  @default(85)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

model ShippingZone {
  id              String         @id @default(cuid())
  shop            String
  // ISO 3166-1 alpha-2 of the country this zone belongs to. Defaults to "CO"
  // so existing rows (created before internationalization) keep their Colombian
  // semantics. Used to gate the Colombian city catalog/fuzzy resolver, pick the
  // admin subdivision list, and label currency — NOT part of the lookup key.
  // `slug` stays unique per shop (see @@unique) so deployed storefront themes
  // that read rules keyed by the existing CO slugs are unaffected.
  country         String         @default("CO")
  department      String          // display label: "Antioquia" (CO) / "California" (US)
  slug            String          // CO: name-based ("antioquia"); other: province-code-based ("ca")
  enabled         Boolean        @default(true)
  // JSON array of service codes available in this zone — derived from Shopify Locations
  // at zone creation, then editable by the merchant. Defaults to all 3 to preserve legacy
  // behavior on rows created before this column existed.
  enabledServices String         @default("[\"mox_envio\",\"mox_express\",\"mox_pickup\"]")
  rates           ShippingRate[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([shop, slug])
}

/// Quote log: una fila por request de tarifas (checkout real o simulador del
/// admin). Es la herramienta de diagnóstico del merchant: guarda el destino,
/// el carrito, qué reglas se evaluaron y por qué se descartaron, y qué rates
/// se devolvieron. Escrito fire-and-forget desde el carrier service para no
/// agregar latencia al checkout. Retención: ver QUOTE_RETENTION_DAYS en
/// quote-log.server.js (limpieza oportunista en cada escritura muestreada).
model RateQuote {
  id             String   @id @default(cuid())
  shop           String
  source         String   @default("checkout") // "checkout" | "simulator"
  country        String   @default("")
  province       String   @default("") // código/nombre crudo que envió Shopify
  city           String   @default("") // ciudad cruda digitada por el cliente
  resolvedCity   String   @default("") // ciudad homologada por el resolver
  resolveMethod  String   @default("") // "exact" | "alias" | "fuzzy" | "none"
  departmentSlug String   @default("")
  itemCount      Int      @default(0)
  cartWeightKg   Float    @default(0)
  cartTotal      Float    @default(0)
  currency       String   @default("")
  items          String   @default("[]") // JSON: snapshot reducido de items del carrito
  decisions      String   @default("[]") // JSON: [{rateId,name,serviceCode,zone,matched,reason,price}]
  steps          String   @default("[]") // JSON: pasos globales (resolución ciudad, zona, selección)
  ratesReturned  String   @default("[]") // JSON: rates devueltas a Shopify
  rateCount      Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([shop, createdAt])
}

model ShippingRate {
  id            String       @id @default(cuid())
  zoneId        String
  zone          ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name          String       // "Envío Express", "Envío Estándar"
  serviceCode   String       // "mox_express", "mox_envio"
  // Amount in MAJOR currency units of the shop currency. Float so currencies
  // with minor units work (USD 12.99); zero-decimal currencies (COP 12000)
  // store whole numbers. Shopify's carrier/total_price hundredths convention
  // (amount * 100) holds across currencies, so existing COP values are
  // unchanged by the Int→Float migration.
  price         Float        // major units: 12000 (COP) | 12.99 (USD)
  description   String       @default("")
  cityCondition String       @default("all") // "all" | "include" | "exclude"
  cities        String       @default("[]")  // JSON array: '["MEDELLÍN","BELLO"]'
  // Merchant-defined nicknames/variants per city for checkout homologation.
  // JSON map canonical→aliases: '{"MEDELLÍN":["medallo","medeya"]}'. Combined
  // with fuzzy matching: a customer city matches when it's within the shop's
  // threshold of any city OR any of its aliases. Additive — empty by default.
  cityAliases   String       @default("{}")
  timeFrom      String?      // "08:00" — hora inicio (Colombia UTC-5), null = sin restricción
  timeTo        String?      // "13:00" — hora fin, null = sin restricción
  daysOfWeek    String       @default("[]") // JSON array: '["mon","tue","wed","thu","fri"]', [] = todos
  // Condición de producto generalizada:
  //  - productCondition: "all" | "include" | "exclude". Los valores legacy
  //    "include_tags"/"exclude_tags" siguen siendo válidos en runtime y
  //    equivalen a include/exclude con productField="tags".
  //  - productField: atributo del item contra el que se comparan los valores.
  //    "tags" | "vendor" | "product_type" | "collection" | "sku".
  //    vendor y sku vienen en el payload del carrier; tags/product_type/
  //    collection se consultan a la Admin API solo si alguna rate los usa.
  //  - productMatchMode: "any" = basta un item que matchee; "all" = todos los
  //    items del carrito deben matchear (ej. carrito 100% congelados).
  //  - productTags: JSON array de valores (nombre histórico — hoy guarda tags,
  //    vendors, tipos, handles/títulos de colección o SKUs según productField).
  productCondition String     @default("all")
  productField     String     @default("tags")
  productMatchMode String     @default("any")
  productTags      String     @default("[]")    // JSON array: '["fragil","pesado"]'
  // Estimado de entrega en días calendario. Si ambos son null no se envía
  // estimado. En checkout se convierten a min/max_delivery_date (hoy + N días)
  // y Shopify los muestra bajo la tarifa ("Llega entre el X y el Y").
  minDeliveryDays Int?
  maxDeliveryDays Int?
  pricingMode     String       @default("flat")  // "flat" | "weight_tiers" | "cart_total"
  weightTiers     String       @default("[]")    // JSON: [{"minKg":0,"maxKg":1,"price":12000},...]
  cartTotalTiers  String       @default("[]")    // JSON: [{"minAmount":0,"maxAmount":100000,"price":12000},...]
  // Bodega de origen — SOLO display/organización en el admin. NO afecta el
  // precio del checkout ni decide qué Location despacha (eso lo resuelve
  // Shopify con Order Routing + inventario). null = derivada automáticamente
  // de la bodega cuya provincia matchea el depto de la zona; un valor es un
  // override del merchant = GID de una Shopify Location.
  warehouseId     String?
  enabled       Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([zoneId])
}
